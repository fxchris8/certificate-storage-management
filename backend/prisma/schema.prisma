// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                @id @default(uuid()) @db.Uuid
  username             String                @unique
  passwordHash         String?               @map("password_hash")
  ssoId                String?               @unique @map("sso_id")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  reviewedSubmissions  ExternalSubmission[]

  @@map("users")
}

model Person {
  id                  String                @id @default(uuid()) @db.Uuid
  name                String
  seafarercode        String
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @updatedAt @map("updated_at")
  certificates        Certificate[]
  externalSubmissions ExternalSubmission[]

  @@map("persons")
}

model Certificate {
  id              String   @id @default(uuid()) @db.Uuid
  personId        String   @map("person_id") @db.Uuid
  certificateName String   @map("certificate_name")
  nomorSertifikat String   @map("nomor_sertifikat")
  fileUrl         String   @map("file_url")
  uploadedAt      DateTime @default(now()) @map("uploaded_at")
  
  // Relationships
  person          Person   @relation(fields: [personId], references: [id])

  @@map("certificates")
}

model ExternalSubmission {
  id                    String   @id @default(uuid()) @db.Uuid
  externalSubmissionId  String   @unique @map("external_submission_id")
  seafarerCode          String   @map("seafarer_code")
  seafarerName          String   @map("seafarer_name")
  certificateName       String   @map("certificate_name")
  nomorSertifikat       String   @map("nomor_sertifikat")
  externalFileUrl       String   @map("external_file_url")
  status                String   @default("PENDING")
  reviewNotes           String?  @map("review_notes")
  reviewedBy            String?  @map("reviewed_by") @db.Uuid
  reviewedAt            DateTime? @map("reviewed_at")
  personId              String?  @map("person_id") @db.Uuid
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  reviewer              User?    @relation(fields: [reviewedBy], references: [id])
  person                Person?  @relation(fields: [personId], references: [id])

  @@map("external_submissions")
}