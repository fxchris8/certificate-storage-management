# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_PORT=5432

# Backend Configuration
NODE_ENV=development
BACKEND_PORT=5000
LOG_LEVEL=info
JWT_SECRET=change-me-jwt-secret-min-32-chars
WHITE_LIST_URLS=http://localhost:3000,http://localhost:5173,http://localhost:5176,http://localhost:5000,http://localhost:8080

# SSO Configuration (optional - leave empty to disable)
SSO_FRONTEND_URL=http://localhost:5173
SSO_BASE_URL=http://host.docker.internal:5000
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_CALLBACK_URL=http://localhost:5000/api/auth/sso/callback
FRONTEND_URL=http://localhost:5176

# SPIL Integration (for receiving external submissions)
EXTERNAL_API_KEY=change-me-api-key

# Frontend Configuration
FRONTEND_PORT=5176
VITE_API_URL=http://localhost:5000/api

# OCR Service Configuration
OCR_PORT=8000

# Google Drive OAuth2 user account
# Generate the refresh token with a Google Drive scope and keep these values secret.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_REDIRECT_URI=http://localhost:8080/oauth2callback
GDRIVE_FOLDER_ID=
