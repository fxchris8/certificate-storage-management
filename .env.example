# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_PORT=5432

# Backend Configuration
NODE_ENV=development
BACKEND_PORT=5000
LOG_LEVEL=info
JWT_SECRET=csm-main-jwt-secret-key-2026-production-ready-secure-token
WHITE_LIST_URLS=http://localhost:3000,http://localhost:5173,http://localhost:5176,http://localhost:5000,http://localhost:8080

# SSO Configuration (optional - leave empty to disable)
