# Database Configuration
POSTGRES_HOST=your_postgres_host_or_ip
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=certificate_db
POSTGRES_PORT=5432

# Backend Configuration
NODE_ENV=production
BACKEND_PORT=5000
LOG_LEVEL=info
JWT_SECRET=your_jwt_secret_minimum_32_characters_long_here
WHITE_LIST_URLS=http://localhost:3000,http://localhost:5173

# Google Drive Service Account (optional)
GDRIVE_CLIENT_EMAIL=your-service-account-email@project.iam.gserviceaccount.com
GDRIVE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GDRIVE_FOLDER_ID=your_google_drive_folder_id

# Frontend Configuration
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:5000

# OCR Service Configuration
OCR_PORT=8000
